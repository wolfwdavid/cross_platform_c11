    "settings.workspaceColors.noCustomColors": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No custom colors yet. Pick one from a workspace context menu → \"Choose Custom Color...\""
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "カスタムカラーはまだありません。ワークスペースのコンテキストメニュー →「カスタムカラーを選択…」から選べます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "暂无自定义颜色。从工作区右键菜单 → 「选取自定义颜色...」中选择。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "尚無自訂顏色。從工作區右鍵選單 →「選擇自訂顏色...」挑一個。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아직 사용자 지정 색상이 없습니다. 작업 공간 컨텍스트 메뉴 → \"사용자 지정 색상 선택...\"에서 선택하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пользовательских цветов пока нет. Выберите в контекстном меню рабочего пространства → «Выбрать пользовательский цвет...»"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Поки що немає своїх кольорів. Оберіть через контекстне меню робочого простору → «Обрати свій колір...»"
          }
        }
      }
    },
    "settings.workspaceColors.paletteNote": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Customize the palette shown under Sidebar > Workspace Color. \"Choose Custom Color...\" entries are kept below."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "サイドバー > ワークスペースカラーに表示されるパレットをカスタマイズします。「カスタムカラーを選択…」のエントリは下に保存されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "自定义「侧边栏 > 工作区颜色」中显示的调色板。「选取自定义颜色...」的条目保留在下方。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "自訂側邊欄 > 工作區顏色下顯示的色板。「選擇自訂顏色...」的項目保存於下方。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사이드바 > 작업 공간 색상에 표시되는 팔레트를 사용자 지정합니다. \"사용자 지정 색상 선택...\" 항목은 아래에 유지됩니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Настройте палитру, отображаемую в Боковая панель > Цвет рабочего пространства. Записи «Выбрать пользовательский цвет...» хранятся ниже."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Налаштуйте палітру під Бічна панель > Колір робочого простору. Записи «Обрати свій колір...» зберігаються нижче."
          }
        }
      }
    },
