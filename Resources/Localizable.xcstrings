    "notifications.empty.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "When a pane needs you, it rings here. Tap one to jump to its pane."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ペインがあなたを必要とするとき、ここで呼びかけます。クリックするとそのペインに移動します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "面板有事,便在此叩你。点一下即刻跳过去。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "窗格有事,便在此叩你。點一下即刻跳過去。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "페인이 당신을 필요로 할 때 여기서 울려요. 알림을 클릭하면 해당 페인으로 이동해요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Когда панели нужно ваше внимание, она звенит здесь. Нажмите, чтобы перейти к ней."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Коли панель потребує вас, вона гукає сюди. Натисніть, щоб перейти до неї."
          }
        }
      }
    },
