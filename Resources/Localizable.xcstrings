    "settings.app.closeWorkspaceOnLastSurfaceShortcut": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Keep Workspace When Last Surface Closes"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最後のサーフェスを閉じてもワークスペースを残す"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "마지막 서피스가 닫힐 때 작업 공간 유지"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭最后一个界面时保留工作区"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "關閉最後一個介面時保留工作區"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сохранять рабочее пространство при закрытии последней поверхности"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Залишати робочий простір при закритті останньої поверхні"
          }
        }
      }
    },
    "settings.app.closeWorkspaceOnLastSurfaceShortcut.subtitleOff": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If the focused surface is the last one, the close-surface shortcut also closes the workspace."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フォーカス中のサーフェスがそのワークスペースの最後の1つなら、サーフェスを閉じるショートカットはワークスペースも閉じます。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Якщо фокусована поверхня — остання, скорочення «закрити поверхню» також закриває робочий простір."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "포커스된 서피스가 마지막이면, 서피스 닫기 단축키가 작업 공간도 닫습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "若聚焦的界面是工作区的最后一个,关闭界面的快捷键也会关闭该工作区。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "若聚焦中的介面是工作區最後一個,關閉介面的快捷鍵也會關閉該工作區。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если активная поверхность — последняя, сочетание «закрыть поверхность» закрывает и рабочее пространство."
          }
        }
      }
    },
    "settings.app.closeWorkspaceOnLastSurfaceShortcut.subtitleOn": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "If the focused surface is the last one, the close-surface shortcut still closes only the surface. Close the workspace explicitly with the close-workspace shortcut."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フォーカス中のサーフェスがそのワークスペースの最後の1つでも、サーフェスを閉じるショートカットはサーフェスだけを閉じ、ワークスペースは残します。ワークスペースを閉じるショートカットを使うと明示的に閉じられます。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Якщо фокусована поверхня — остання, скорочення «закрити поверхню» все одно закриває тільки поверхню. Закрийте робочий простір явно скороченням «закрити робочий простір»."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "포커스된 서피스가 마지막이어도, 서피스 닫기 단축키는 서피스만 닫습니다. 작업 공간은 작업 공간 닫기 단축키로 명시적으로 닫으세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "即便聚焦的界面是工作区的最后一个,关闭界面的快捷键仍只关闭界面。关闭工作区请使用关闭工作区的快捷键。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "即使聚焦中的介面是工作區最後一個,關閉介面的快捷鍵也只會關閉介面,保留工作區。用關閉工作區的快捷鍵才會明確關閉。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Если активная поверхность — последняя, сочетание «закрыть поверхность» всё равно закрывает только поверхность. Рабочее пространство закройте явно сочетанием «закрыть рабочее пространство»."
          }
        }
      }
    },
