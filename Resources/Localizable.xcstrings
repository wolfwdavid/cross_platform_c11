    "settings.page.agents.helper": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "the A button on every pane launches an agent. shape what runs and what it knows about c11."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "各ペインの A ボタンはエージェントを起動します。何が実行され、c11 について何を知っているかを形作ります。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Кнопка A на кожній панелі запускає агента. Визначте, що запускається і що він знає про c11."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "각 패널의 A 버튼이 에이전트를 실행합니다. 무엇이 실행되고 에이전트가 c11에 대해 무엇을 아는지 정합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每个窗格上的 A 按钮启动一个代理。决定运行什么以及它对 c11 了解什么。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "每個窗格上的 A 按鈕啟動一個代理。決定執行什麼以及它對 c11 了解什麼。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Кнопка A на каждой панели запускает агента. Определите, что запускается и что он знает о c11."
          }
        }
      }
    },
