          }
        }
      }
    },
    "createWorkspace.recents.empty.hint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Pick a directory above, browse to one, or drag a folder here."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "上でディレクトリを選択するか、参照するか、フォルダをここにドラッグしてください。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Виберіть директорію вище, перегляньте файлову систему або перетягніть папку сюди."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "위에서 디렉터리를 선택하거나, 찾아보거나, 폴더를 여기로 드래그하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在上方选择目录，浏览查找，或将文件夹拖到此处。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在上方選擇目錄，瀏覽查找，或將資料夾拖到此處。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Выберите директорию выше, найдите её через обзор или перетащите папку сюда."
          }
        }
      }
    },
