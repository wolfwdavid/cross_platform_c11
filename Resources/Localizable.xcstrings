    "dialog.closeLastTabWindow.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This is the last tab. Closing it closes the window."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "これが最後のタブです。閉じるとウインドウも閉じます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅剩此一页。关了它,窗口也关。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "僅剩此一頁。關了它,視窗也關。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "마지막 탭이에요. 닫으면 윈도우도 닫혀요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Это последняя вкладка. Закроете её — закроется и окно."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Це остання вкладка. Її закриття закриє вікно."
          }
        }
      }
    },
