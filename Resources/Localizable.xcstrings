          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "변경 사항이 브라우저 프로필 팝오버에 실시간으로 반영됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "变更会实时应用到浏览器配置文件弹出框。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "變更會即時套用至瀏覽器設定檔彈出視窗。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Изменения применяются вживую к всплывающему окну профиля браузера."
          }
        }
      }
    },
    "debug.browserProfilePopover.note": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tune profile popover padding live while comparing against the browser toolbar menu."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブラウザーツールバーのメニューと見比べながら、プロファイルポップオーバーの余白をライブで調整します。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "브라우저 툴바 메뉴와 비교하면서 프로필 팝오버 패딩을 실시간으로 조정합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在与浏览器工具栏菜单对比时,实时调整个人资料弹出框的边距。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "即時調整個人檔案彈出視窗的內距，同時對照瀏覽器工具列選單。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Настраивайте отступы всплывающего меню профиля вживую, сравнивая с меню панели инструментов браузера."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Налаштовуйте відступи спливного вікна профілю наживо, порівнюючи з меню панелі браузера."
          }
        }
      }
    },
