    },
    "settings.automation.openAccess.dialog.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Disables ancestry and password checks. Opens the socket to every local user on this Mac. Only enable if you understand the risk."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "祖先プロセスチェックとパスワードチェックを無効にします。このMac上のすべてのローカルユーザーにソケットを公開します。リスクを理解した場合のみ有効にしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "禁用祖先和密码检查。向本 Mac 上每个本地用户开放套接字。仅在了解风险后启用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "停用來源驗證和密碼檢查，將 Socket 開放給此 Mac 上的所有本機使用者。了解風險後再啟用。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "출처 및 비밀번호 검사를 비활성화합니다. 이 Mac의 모든 로컬 사용자에게 소켓을 개방합니다. 위험을 이해한 경우에만 활성화하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отключает проверку происхождения и пароля. Открывает сокет всем локальным пользователям этого Mac. Включайте, только если понимаете риски."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Вимикає перевірки походження та пароля. Відкриває сокет для всіх локальних користувачів цього Mac. Вмикайте, лише якщо розумієте ризик."
          }
        }
      }
    },
    "settings.automation.openAccess.dialog.title": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable full open access?"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "フルオープンアクセスを有効にしますか？"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启用完全开放访问？"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "要啟用完全開放存取嗎？"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "전체 개방 접근을 활성화하시겠습니까?"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Включить полный открытый доступ?"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Увімкнути повний відкритий доступ?"
          }
        }
      }
    },
    "settings.automation.openAccessWarning": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Warning: Full open access makes the control socket world-readable/writable on this Mac and disables auth checks. Local debugging only."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "警告: フルオープンアクセスにすると、このMac上の制御ソケットが誰でも読み書き可能になり、認証チェックが無効になります。ローカルデバッグ専用。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "警告：完全开放访问会使控制套接字在本 Mac 上对所有用户可读/可写，并禁用身份验证检查。仅用于本地调试。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "警告：完全開放存取會讓控制 Socket 在此 Mac 上可被所有人讀寫，並停用驗證檢查。僅限本機除錯使用。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "경고: 전체 개방 접근은 이 Mac에서 제어 소켓을 누구나 읽고 쓸 수 있게 하며 인증 검사를 비활성화합니다. 로컬 디버깅 전용."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Внимание: полный открытый доступ делает управляющий сокет доступным для чтения и записи всем на этом Mac и отключает проверку авторизации. Только для локальной отладки."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Попередження: повний відкритий доступ робить керуючий сокет читальним і записувальним для всіх на цьому Mac та вимикає перевірки авторизації. Лише для локального зневадження."
          }
        }
      }
    },
    "settings.automation.port.note": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Each workspace gets a dedicated port range via CMUX_PORT and CMUX_PORT_END. New terminals inherit them."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "各ワークスペースにはCMUX_PORTとCMUX_PORT_ENDで専用のポート範囲が割り当てられます。新しいターミナルはこれを継承します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每个工作区通过 CMUX_PORT 和 CMUX_PORT_END 获得专用端口范围。新终端将继承这些值。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "每個工作區透過 CMUX_PORT 和 CMUX_PORT_END 取得專用連接埠範圍。新終端機會繼承這些值。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "각 작업 공간은 CMUX_PORT 및 CMUX_PORT_END를 통해 전용 포트 범위를 받습니다. 새 터미널은 이 값을 상속합니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Каждое рабочее пространство получает выделенный диапазон портов через CMUX_PORT и CMUX_PORT_END. Новые терминалы наследуют их."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Кожен робочий простір отримує виділений діапазон портів через CMUX_PORT і CMUX_PORT_END. Нові термінали успадковують їх."
          }
        }
      }
    },
