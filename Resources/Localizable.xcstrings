    "settings.shortcuts.showHints.subtitleOff": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Holding Cmd or Ctrl keeps shortcut hints hidden."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "CmdまたはCtrlを長押ししてもショートカットヒントは非表示のままです。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按住 Cmd 或 Ctrl 时保持隐藏快捷键提示。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "按住 Cmd 或 Ctrl 時快速鍵提示保持隱藏。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Cmd 또는 Ctrl을 눌러도 단축키 힌트가 숨겨진 상태로 유지됩니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удержание Cmd или Ctrl не показывает подсказки сочетаний."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Утримання Cmd або Ctrl не показує підказки скорочень."
          }
        }
      }
    },
    "settings.shortcuts.showHints.subtitleOn": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Holding Cmd (sidebar/titlebar) or Ctrl/Cmd (pane tabs) reveals shortcut hints."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Cmd（サイドバー/タイトルバー）またはCtrl/Cmd（ペインタブ）を長押しするとショートカットヒントが表示されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "按住 Cmd（侧边栏/标题栏）或 Ctrl/Cmd（面板标签页）显示快捷键提示。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "按住 Cmd（側邊欄/標題列）或 Ctrl/Cmd（面板標籤頁）顯示快速鍵提示。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Cmd(사이드바/제목 표시줄) 또는 Ctrl/Cmd(패널 탭)를 누르면 단축키 힌트가 표시됩니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Удержание Cmd (боковая панель/заголовок) или Ctrl/Cmd (вкладки панели) показывает подсказки сочетаний."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Утримання Cmd (бічна панель/смуга заголовка) або Ctrl/Cmd (вкладки панелей) показує підказки скорочень."
          }
        }
      }
    },
