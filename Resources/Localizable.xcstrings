    "settings.reset.coverage": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Resets language, app behavior, browser routing, import hints, notifications, sidebar detail and tint, shortcuts, TextBox input, and workspace colors."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "言語、アプリ動作、ブラウザのルーティング、インポートヒント、通知、サイドバー詳細と色合い、ショートカット、TextBox入力、ワークスペースカラーをリセットします。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "언어, 앱 동작, 브라우저 라우팅, 가져오기 힌트, 알림, 사이드바 세부 정보 및 색조, 단축키, TextBox 입력, 작업 공간 색상을 재설정합니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "重置语言、应用行为、浏览器路由、导入提示、通知、侧边栏详情和色调、快捷键、TextBox 输入以及工作区颜色。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "重設語言、App 行為、瀏覽器路由、匯入提示、通知、側邊欄詳細資訊和色調、快速鍵、TextBox 輸入以及工作區顏色。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сбрасывает язык, поведение приложения, маршрутизацию браузера, подсказки импорта, уведомления, детали и оттенок боковой панели, сочетания клавиш, ввод TextBox и цвета рабочих пространств."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Скидає мову, поведінку застосунку, маршрутизацію браузера, підказки імпорту, сповіщення, деталі й відтінок бічної панелі, клавіатурні скорочення, введення в TextBox і кольори робочих просторів."
          }
        }
      }
    },
    "settings.reset.externalState": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reset Settings leaves c11 theme slots, port ranges, browser history, socket password files, agent skill install state, and macOS notification permission alone. Clear browser history above; change the rest where it lives."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "「設定をリセット」は、c11テーマスロット、ポート範囲、ブラウザ履歴、ソケットパスワードファイル、エージェントスキルのインストール状態、macOS通知権限をそのまま残します。ブラウザ履歴は上で消去し、それ以外はそれぞれの場所で変更してください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설정 재설정은 c11 테마 슬롯, 포트 범위, 브라우저 기록, 소켓 비밀번호 파일, 에이전트 스킬 설치 상태, macOS 알림 권한을 그대로 둡니다. 브라우저 기록은 위에서 지우고, 나머지는 해당 위치에서 변경하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "重置设置不会改动 c11 主题槽、端口范围、浏览器历史记录、套接字密码文件、代理技能安装状态和 macOS 通知权限。浏览器历史记录请在上方清除；其余项请在各自位置更改。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "「重設設定」不會變更 c11 主題配置、連接埠範圍、瀏覽器歷史記錄、Socket 密碼檔案、代理人技能安裝狀態以及 macOS 通知權限。在上方清除瀏覽器歷史記錄；其餘請到各自所在位置變更。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Сброс настроек не затрагивает слоты тем c11, диапазоны портов, историю браузера, файлы паролей сокета, состояние установки навыков агентов и разрешение уведомлений macOS. Историю браузера очистите выше; остальное меняйте там, где оно находится."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "«Скинути налаштування» не чіпає слоти тем c11, діапазони портів, історію браузера, файли паролів сокета, стан встановлення навичок агентів і дозвіл на сповіщення macOS. Очистіть історію браузера вище; решту змінюйте там, де вона зберігається."
          }
        }
      }
    },
