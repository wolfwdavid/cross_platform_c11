    "settings.notifications.command.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Runs with /bin/sh -c when a notification fires. Title, subtitle, and body land in CMUX_NOTIFICATION_* env vars."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "通知発火時に /bin/sh -c で実行します。タイトル、サブタイトル、本文は CMUX_NOTIFICATION_* 環境変数に入ります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "알림이 울릴 때 /bin/sh -c로 실행됩니다. 제목, 부제목, 본문은 CMUX_NOTIFICATION_* 환경 변수로 전달됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "通知触发时以 /bin/sh -c 执行。标题、副标题与正文会传入 CMUX_NOTIFICATION_* 环境变量。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "通知觸發時以 /bin/sh -c 執行。標題、副標題和內文放入 CMUX_NOTIFICATION_* 環境變數。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Запускается через /bin/sh -c при срабатывании уведомления. Заголовок, подзаголовок и текст попадают в переменные окружения CMUX_NOTIFICATION_*."
          }
        },
