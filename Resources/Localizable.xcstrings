    "agentSkills.onboarding.noDetectedTools": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Nothing detected yet. Install Claude Code, Codex, or another supported agent, then re-open this from Settings → Agent Skills."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "まだ何も検出されていません。Claude Code、Codex、または対応する他のエージェントをインストールしてから、設定 → エージェントスキル から再度開いてください。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Поки що нічого не знайдено. Встановіть Claude Code, Codex або іншого підтримуваного агента, потім знову відкрийте це з Налаштування → Навички агента."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아직 감지된 게 없어요. Claude Code, Codex 또는 지원되는 다른 에이전트를 설치한 뒤, 설정 → 에이전트 스킬에서 다시 여세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "暂未检测到。先安装 Claude Code、Codex 或其他受支持的代理,再从「设置 → 代理技能」重新打开。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "尚未偵測到任何項目。請先安裝 Claude Code、Codex 或其他支援的代理,再從「設定 → Agent Skills」重新開啟此畫面。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пока ничего не обнаружено. Установите Claude Code, Codex или другого поддерживаемого агента, затем снова откройте это из «Настройки → Навыки агента»."
          }
        }
      }
    },
