    "settings.browser.interceptOpen.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Off: `open https://...` and `open http://...` go to your default browser."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オフ時: `open https://...`と`open http://...`はデフォルトブラウザへ。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "关闭时：`open https://...` 和 `open http://...` 交由默认浏览器处理。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "關閉時：`open https://...` 和 `open http://...` 會交給預設瀏覽器。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "끄면 `open https://...` 및 `open http://...`가 기본 브라우저로 갑니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отключено: `open https://...` и `open http://...` открываются в браузере по умолчанию."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Вимкнено: `open https://...` та `open http://...` ідуть у стандартний браузер."
          }
        }
      }
    },
    "settings.browser.linkRouting.note": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Link interception decides where terminal URL actions land. Sidebar PR links live on Workspace & Sidebar."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "リンクのインターセプトはターミナルのURL操作の行き先を決めます。サイドバーのPRリンクは「ワークスペースとサイドバー」にあります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "링크 인터셉션이 터미널 URL 동작의 목적지를 결정합니다. 사이드바 PR 링크는 Workspace & Sidebar에서 관리됩니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "链接拦截决定终端 URL 操作的去向。侧边栏 PR 链接在「工作区与侧边栏」中设置。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "連結攔截決定終端機 URL 動作的開啟位置。側邊欄 PR 連結設定在「工作區與側邊欄」。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Перехват ссылок решает, куда направлять URL из терминала. Ссылки на PR в боковой панели настраиваются в «Рабочее пространство и боковая панель»."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Перехоплення посилань визначає, куди потрапляють URL-дії терміналу. Посилання PR у бічній панелі — у розділі «Робочі простори та бічна панель»."
          }
        }
      }
    },
    "settings.browser.openTerminalLinks": {
