    "settings.defaultAgent.note": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "the A button on every pane launches this. new terminal still opens bash. drop a `.c11/agents.json` in any repo to override these settings for terminals opened there."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "各ペインの A ボタンはこれを起動します。新規ターミナルは引き続き bash を開きます。これらの設定をリポジトリ単位で上書きするには `.c11/agents.json` を置きます。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Кнопка A на кожній панелі запускає це. Новий термінал, як і раніше, відкриває bash. Покладіть `.c11/agents.json` у будь-який репозиторій, щоб перевизначити ці налаштування для терміналів, відкритих у ньому."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "각 패널의 A 버튼이 이것을 실행합니다. 새 터미널은 여전히 bash를 엽니다. 그곳에서 열리는 터미널의 설정을 재정의하려면 어떤 저장소에든 `.c11/agents.json`을 넣으세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每个窗格上的 A 按钮启动它。新建终端仍打开 bash。在任意仓库放入 `.c11/agents.json` 即可覆盖在该处打开的终端的设置。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "每個窗格上的 A 按鈕啟動它。新增終端機仍開啟 bash。在任一儲存庫放入 `.c11/agents.json` 即可覆寫在該處開啟的終端機的設定。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Кнопка A на каждой панели запускает его. Новый терминал по-прежнему открывает bash. Положите `.c11/agents.json` в любой репозиторий, чтобы переопределить эти настройки для терминалов, открытых там."
          }
        }
      }
    },
