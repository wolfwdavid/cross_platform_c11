    "settings.dataPrivacy.telemetry.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Anonymous crash and usage data leaves this Mac only when on."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "オンのときだけ、匿名のクラッシュデータと使用状況データがこのMacから送信されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "켜져 있을 때만 익명 충돌 및 사용 데이터가 이 Mac을 떠납니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅在开启时，匿名崩溃和使用数据才会离开本 Mac。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "開啟後，匿名當機和使用資料才會傳出此 Mac。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Анонимные данные о сбоях и использовании покидают этот Mac только при включении."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Анонімні дані про збої й використання залишають цей Mac лише коли ввімкнено."
          }
        }
      }
    },
    "settings.defaultAgent.command.help": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "the shell line that runs when you click A. edit it like any other command."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "A をクリックしたときに実行されるシェル行です。通常のコマンドと同じように編集できます。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Рядок оболонки, який запускається, коли ви натискаєте A. Редагуйте його як будь-яку іншу команду."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "A를 클릭하면 실행되는 셸 라인입니다. 다른 명령처럼 편집하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "点击 A 时运行的 shell 命令行。可以像编辑其他命令一样编辑它。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "點擊 A 時執行的 shell 指令行。可以像編輯其他指令一樣編輯它。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Строка оболочки, выполняемая при нажатии A. Редактируйте её как любую другую команду."
          }
        }
      }
    },
    "settings.defaultAgent.command.help.format": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "the shell line that runs when we launch the %@ agent. you can include any parameters to match your specification."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ エージェントを起動するときに実行されるシェル行です。仕様に合わせて任意のパラメータを含められます。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Рядок оболонки, який запускається, коли ми запускаємо агента %@. Ви можете включити будь-які параметри відповідно до ваших вимог."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 에이전트를 실행할 때 실행되는 셸 라인입니다. 사양에 맞춰 어떤 매개변수든 포함할 수 있습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "启动 %@ 代理时运行的 shell 命令行。可以包含任意符合规范的参数。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "啟動 %@ 代理時執行的 shell 指令行。可以包含任意符合規範的參數。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Строка оболочки, выполняемая при запуске агента %@. Можете включить любые параметры согласно вашей спецификации."
          }
        }
      }
    },
