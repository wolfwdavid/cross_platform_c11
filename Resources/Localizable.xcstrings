    "contextMenu.workspaceColor.tooltip": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Per-workspace accent. c11 theme (Light/Dark) lives in Settings → Theme."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ワークスペースごとのアクセント。c11 テーマ（ライト／ダーク）は「設定」→「テーマ」にあります。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "작업 공간별 강조색. c11 테마(라이트/다크)는 설정 → 테마에 있습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "每个工作区的强调色。c11 主题（浅色/深色）位于设置 → 主题。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "各工作區強調色。c11 主題（淺色／深色）位於「設定 → 主題」。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Акцент для рабочего пространства. Тема c11 (светлая/тёмная) — в Настройки → Тема."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Акцент для кожного робочого простору. Тема c11 (світла/темна) — Налаштування → Тема."
          }
        }
      }
    },
