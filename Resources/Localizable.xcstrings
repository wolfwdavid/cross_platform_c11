    "agentSkills.error.destNotManaged": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ exists, but c11 didn't put it there. Use Update or Refresh to replace it."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ は存在しますが、c11 が配置したものではありません。「アップデート」または「更新」で置き換えてください。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@이(가) 있지만 c11이 만든 게 아니에요. 바꾸려면 업데이트나 새로고침을 사용하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 已存在，但不是 c11 放置的。使用“更新”或“刷新”来替换。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 已存在，但不是 c11 放置的。請使用「更新」或「重新整理」來取代。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ существует, но создан не c11. Используйте «Обновить» или «Перечитать» для замены."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ існує, але не c11 його туди розмістив. Скористайтеся «Оновити» або «Перевстановити», щоб замінити."
          }
        }
      }
    },
