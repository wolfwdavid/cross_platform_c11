    "settings.browser.httpAllowlist.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Which HTTP (non-HTTPS) hosts open in c11 without a warning. Defaults: localhost, 127.0.0.1, ::1, 0.0.0.0, *.localtest.me."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "警告なしでc11で開くHTTP（非HTTPS）ホスト。デフォルト: localhost、127.0.0.1、::1、0.0.0.0、*.localtest.me。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "哪些 HTTP（非 HTTPS）主机在 c11 中打开时不显示警告。默认：localhost、127.0.0.1、::1、0.0.0.0、*.localtest.me。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "哪些 HTTP（非 HTTPS）主機在 c11 中開啟而不顯示警告。預設：localhost、127.0.0.1、::1、0.0.0.0、*.localtest.me。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "c11에서 경고 없이 열리는 HTTP(비HTTPS) 호스트. 기본값: localhost, 127.0.0.1, ::1, 0.0.0.0, *.localtest.me."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Какие HTTP (не HTTPS) хосты открываются в c11 без предупреждения. По умолчанию: localhost, 127.0.0.1, ::1, 0.0.0.0, *.localtest.me."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Які HTTP-хости (не HTTPS) відкриваються в c11 без попередження. Типово: localhost, 127.0.0.1, ::1, 0.0.0.0, *.localtest.me."
          }
        }
      }
    },
