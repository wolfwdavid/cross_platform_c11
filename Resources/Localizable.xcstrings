    "dialog.enableNotifications.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Notifications are off for c11. Enable them in System Settings so c11 can ring you when a pane needs attention."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "c11 の通知がオフです。システム設定で有効にすれば、ペインがあなたを必要とするときに c11 が呼びかけます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "c11 的通知已关。到「系统设置」里开启,面板有事时,c11 才叩得到你。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "c11 的通知已關。到「系統設定」裡開啟,窗格有事時,c11 才叩得到你。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "c11의 알림이 꺼져 있어요. 시스템 설정에서 켜면 페인에 주의가 필요할 때 c11이 울려요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Уведомления для c11 выключены. Включите их в Системных настройках, чтобы c11 мог звенеть, когда панели нужно внимание."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Сповіщення для c11 вимкнені. Увімкніть їх у Системних налаштуваннях, щоб c11 міг гукати вас, коли панель потребує уваги."
          }
        }
      }
    },
