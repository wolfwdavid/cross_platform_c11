      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The blank-tab import hint is hidden. Turn it back on any time."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "空タブのインポート案内は非表示です。ここでいつでも再表示できます。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Підказку про імпорт на порожній вкладці приховано. Увімкніть її знову в будь-який момент."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "빈 탭의 가져오기 힌트가 숨겨져 있어요. 언제든 다시 켤 수 있어요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "空白标签上的导入提示已隐藏。随时可重新打开。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "空白標籤頁的匯入提示已隱藏。隨時可以重新開啟。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Подсказка импорта на пустой вкладке скрыта. Включите её снова в любой момент."
          }
        }
      }
    },
    "settings.browser.import.hint.note.settingsOnly": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Blank tabs are on Settings-only mode from the debug window."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "空タブはデバッグウィンドウの「設定のみ」モードです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "빈 탭이 디버그 창의 설정 전용 모드로 설정되어 있습니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "空白标签页通过调试窗口处于「仅设置」模式。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "空白分頁目前使用來自除錯視窗的「僅設定」模式。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пустые вкладки работают в режиме «Только настройки» из окна отладки."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Порожні вкладки працюють у режимі «лише налаштування», заданому з вікна зневадження."
          }
        }
      }
    },
    "settings.browser.import.hint.note.visible": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Blank browser tabs can show this import suggestion. Hide or re-enable it here."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "空のブラウザータブにこのインポート案内を表示できます。ここで非表示や再表示を切り替えられます。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Порожні вкладки браузера можуть показувати цю пропозицію імпорту. Приховайте або ввімкніть її тут."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "빈 브라우저 탭에 이 가져오기 제안을 표시할 수 있어요. 여기서 숨기거나 다시 활성화하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "空白浏览器标签可以显示这条导入建议。可在此处隐藏或重新启用。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "空白的瀏覽器標籤頁可顯示此匯入建議。可在這裡隱藏或重新啟用。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пустые вкладки браузера могут показывать это предложение импорта. Скройте или включите её снова здесь."
          }
        }
      }
    },
