    "about.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "terminal command center for the operator:agent pair.\nmany surfaces. one workspace. one field of view."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "操作者・エージェントのためのターミナル司令室。\n多くのサーフェス。ひとつのワークスペース。ひとつの視界。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "为「操作员·代理」一体而设的终端指挥中枢。\n多个界面。一个工作区。一视同观。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "為「操作員·代理」一體而設的終端指揮中樞。\n面面有界,事事一區,同視一處。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "오퍼레이터·에이전트 페어를 위한 터미널 커맨드 센터.\n여러 서피스. 하나의 워크스페이스. 하나의 시야."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "терминальный командный центр для пары оператор–агент.\nмного поверхностей. одно рабочее пространство. одно поле зрения."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "термінальний командний центр для пари оператор–агент.\nбагато поверхонь. один робочий простір. одне поле зору."
          }
        }
      }
    },
