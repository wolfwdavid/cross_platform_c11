    "settings.browser.hostWhitelist": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hosts to Open in Embedded Browser"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "内蔵ブラウザで開くホスト"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在内嵌浏览器中打开的主机"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在內建瀏覽器中開啟的主機"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "내장 브라우저에서 열 호스트"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Хосты для открытия во встроенном браузере"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Хости для відкриття у вбудованому браузері"
          }
        }
      }
    },
    "settings.browser.hostWhitelist.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Applies to terminal link clicks and intercepted `open https://...` calls. Only these hosts open in c11; the rest go to your default browser. One host or wildcard per line (example: example.com, *.internal.example). Leave empty to open every host in c11."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ターミナルのリンククリックおよびインターセプトされた`open https://...`呼び出しに適用されます。c11で開くのはこれらのホストのみ。その他はデフォルトブラウザへ。1行に1つのホストまたはワイルドカード（例: example.com, *.internal.example）。空欄にするとすべてのホストをc11で開きます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "适用于终端链接点击和拦截的 `open https://...` 调用。仅这些主机在 c11 中打开，其余交由默认浏览器处理。每行一个主机或通配符（例如：example.com、*.internal.example）。留空则所有主机均在 c11 中打开。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "套用於終端機連結點擊和攔截的 `open https://...` 呼叫。僅這些主機會在 c11 中開啟，其餘會交給預設瀏覽器。每行一個主機或萬用字元（例如：example.com、*.internal.example）。留空則所有主機都在 c11 中開啟。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "터미널 링크 클릭 및 인터셉트된 `open https://...` 호출에 적용됩니다. 이 호스트만 c11에서 열리고, 나머지는 기본 브라우저로 갑니다. 한 줄에 하나의 호스트 또는 와일드카드 (예: example.com, *.internal.example). 비워두면 모든 호스트가 c11에서 열립니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Применяется к нажатиям ссылок в терминале и перехваченным вызовам `open https://...`. Только эти хосты открываются в c11; остальные — в браузере по умолчанию. Один хост или шаблон на строку (например: example.com, *.internal.example). Оставьте пустым, чтобы открывать все хосты в c11."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Застосовується до кліків на посилання в терміналі й перехоплених викликів `open https://...`. Лише ці хости відкриваються в c11; решта — у стандартному браузері. Один хост або шаблон на рядок (приклад: example.com, *.internal.example). Залиште порожнім, щоб усі хости відкривались у c11."
          }
        }
      }
    },
    "settings.browser.httpAllowlist": {
      "extractionState": "manual",
      "localizations": {
        "en": {
