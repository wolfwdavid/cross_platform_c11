    "dialog.renameTab.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Any text works. Longer titles are easier to find when many tabs are open."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "どんな文字列でも使えます。タブが多いときは長めのタイトルのほうが見分けやすくなります。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "随便起。标签多的时候,名字长一点更好找。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "隨便取。標籤多的時候,名字長一點更好找。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "아무 텍스트나 가능해요. 탭이 많을 때는 긴 제목이 찾기 쉬워요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Любой текст подойдёт. Длинные названия проще найти, когда открыто много вкладок."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Будь-який текст підходить. Довші назви легше знайти, коли відкрито багато вкладок."
          }
        }
      }
    },
