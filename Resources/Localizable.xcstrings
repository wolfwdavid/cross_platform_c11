          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Keychain から %3$@ を開けなかったため、暗号化された %2$@ の Cookie を %1$ld 件スキップしました。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Пропущено %1$ld зашифрованих cookie %2$@ — %3$@ не вдалося розблокувати в Keychain."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "암호화된 %2$@ 쿠키 %1$ld개를 건너뛰었어요 — %3$@을(를) Keychain에서 잠금 해제할 수 없었어요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "跳过了 %1$ld 个已加密的 %2$@ cookie — 无法从钥匙串解锁 %3$@。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "因為無法從 Keychain 解開 %3$@,已略過 %1$ld 個加密的 %2$@ Cookie。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Пропущено %1$ld зашифрованных cookie %2$@ — %3$@ не удалось разблокировать в Keychain."
          }
        }
