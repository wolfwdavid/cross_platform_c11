    "browser.import.warning.additionalDataUnavailable": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Bookmarks, settings, and extensions aren't supported yet — only cookies and history were imported."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ブックマーク、設定、拡張機能のインポートにはまだ対応していません。Cookie と履歴のみを取り込みました。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Закладки, налаштування та розширення поки не підтримуються — імпортовано лише cookie та історію."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "북마크, 설정, 확장 프로그램은 아직 지원되지 않아요 — 쿠키와 기록만 가져왔어요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "暂不支持书签、设置和扩展 — 仅导入了 cookie 和历史。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "書籤、設定、擴充功能尚未支援 — 僅匯入了 Cookie 與歷史紀錄。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Закладки, настройки и расширения пока не поддерживаются — импортированы только cookie и история."
          }
        }
      }
    },
