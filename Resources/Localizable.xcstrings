    "debug.browserProfilePopover.liveNote": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Changes apply live to the browser profile popover."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "変更はブラウザープロファイルポップオーバーにライブで反映されます。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
