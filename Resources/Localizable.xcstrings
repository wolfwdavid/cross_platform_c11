    "settings.automation.claudeCode.note": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Wraps the claude command to inject session tracking and notification hooks. Turn off to manage Claude Code hooks yourself."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "claudeコマンドをラップしてセッション追跡と通知フックを挿入します。Claude Codeのフックを自分で管理するにはオフにしてください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "包装 claude 命令以注入会话跟踪和通知钩子。关闭后可自行管理 Claude Code 钩子。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "包裝 claude 指令以注入工作階段追蹤和通知掛鉤。關閉即可自行管理 Claude Code 掛鉤。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "claude 명령을 래핑하여 세션 추적 및 알림 훅을 삽입합니다. Claude Code 훅을 직접 관리하려면 끄세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Оборачивает команду claude для внедрения хуков отслеживания сеансов и уведомлений. Отключите, чтобы управлять хуками Claude Code самостоятельно."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Обгортає команду claude, щоб додати відстеження сесій і хуки сповіщень. Вимкніть, щоб керувати хуками Claude Code самостійно."
          }
        }
      }
    },
