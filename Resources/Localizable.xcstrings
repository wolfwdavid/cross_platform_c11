    "createWorkspace.name.hint": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Defaults to the directory name. Override to give this workspace a custom label."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ディレクトリ名がデフォルトです。このワークスペースにカスタムラベルを付ける場合は上書きしてください。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "За замовчуванням — назва директорії. Перевизначте, щоб дати робочому простору власну мітку."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "기본값은 디렉터리 이름입니다. 이 워크스페이스에 사용자 정의 레이블을 지정하려면 재정의하세요."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "默认为目录名称。如要为该工作区指定自定义标签，请覆盖。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "預設為目錄名稱。如要為該工作區指定自訂標籤，請覆寫。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "По умолчанию — имя директории. Переопределите, чтобы задать этому рабочему пространству своё имя."
          }
        }
      }
    },
    "createWorkspace.recents.caption": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "or select from your recent directories:"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
