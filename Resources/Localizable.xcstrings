    "settings.appearance.c11Theme.note": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "c11 theme changes app chrome only. Ghostty terminal themes are separate."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "c11テーマはアプリのクロームだけを変更します。Ghosttyのターミナルテーマは別です。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "c11 테마는 앱 크롬만 변경합니다. Ghostty 터미널 테마는 별도입니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "c11 主题仅改变应用外观。Ghostty 终端主题相互独立。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "c11 主題僅變更應用外殼。Ghostty 終端機主題獨立運作。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Тема c11 меняет только оформление приложения. Темы терминала Ghostty — отдельно."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Тема c11 змінює тільки хром застосунку. Теми терміналу Ghostty — окремо."
          }
        }
      }
    },
