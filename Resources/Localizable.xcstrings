    "markdown.empty.spikePropaganda": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Plans, docs, receipts — the Spike runs on markdown. Drop in, one workspace."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "計画・ドキュメント・履歴 — Spike はマークダウンで動く。すべてを一つのワークスペースへ。"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Плани, документи, сліди — Spike працює на markdown. Киньте сюди, один робочий простір."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "계획, 문서, 흔적 — Spike는 마크다운 위에서 돕니다. 여기로 끌어 놓으세요, 하나의 작업 공간."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "计划、文档、凭据 — Spike 以 markdown 运转。拖进来,一个工作区。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "計畫、文件、紀錄 — Spike 靠 markdown 運轉。丟進來,一個工作區。"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Планы, документы, следы — Spike работает на markdown. Бросьте сюда, одно рабочее пространство."
          }
        }
      }
    },
