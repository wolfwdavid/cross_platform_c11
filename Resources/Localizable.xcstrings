    "browser.error.insecure.message": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ uses plain HTTP, so traffic can be read or modified on the network.\n\nOpen this URL in your default browser, or proceed in c11."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ は HTTP 接続を使用しているため、通信内容がネットワーク上で読み取られたり改ざんされる可能性があります。\n\nデフォルトブラウザで開くか、c11 で続行してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 使用纯 HTTP 连接，网络上的流量可能被读取或修改。\n\n请在默认浏览器中打开此 URL，或在 c11 中继续访问。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ 使用未加密的 HTTP，網路上的流量可能被讀取或竄改。\n\n在您的預設瀏覽器中開啟此 URL，或在 c11 中繼續。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "%@은(는) 일반 HTTP를 사용하므로, 네트워크에서 트래픽이 읽히거나 변조될 수 있습니다.\n\n기본 브라우저에서 이 URL을 열거나, c11에서 계속 진행하세요."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ использует незащищенный протокол HTTP, поэтому трафик может быть перехвачен или изменен в сети.\n\nОткройте этот URL в браузере по умолчанию или продолжите в c11."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "%@ використовує незахищений HTTP, тому трафік можуть прочитати або змінити у мережі.\n\nВідкрийте цю URL у типовому браузері або продовжте в c11."
          }
        }
      }
    },
