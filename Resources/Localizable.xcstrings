    "settings.agentLauncher.customCommand.subtitle": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Sent to the new terminal as if typed. Runs inside your shell."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "入力されたかのように新しいターミナルへ送信されます。お使いのシェル内で実行されます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "如同输入一般发送至新终端。在您的 shell 中运行。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "如同輸入般傳送至新終端機。在您的 shell 中執行。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "입력된 것처럼 새 터미널로 전송됩니다. 셸 내부에서 실행됩니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отправляется в новый терминал, как если бы было введено вручную. Выполняется в вашей оболочке."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Надсилається до нового термінала, ніби його ввели вручну. Виконується у вашій оболонці."
          }
        }
      }
    },
    "settings.agentLauncher.kind": {
      "extractionState": "manual",
      "localizations": {
        "en": {
