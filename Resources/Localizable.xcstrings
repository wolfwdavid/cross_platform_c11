    "socketControl.cmuxOnly.description": {
      "extractionState": "manual",
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Only processes started inside c11 terminals can send commands."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "c11 ターミナル内で起動したプロセスのみがコマンドを送信できます。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "仅允许在 c11 终端内启动的进程发送命令。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "僅在 c11 終端機內啟動的程序可以傳送指令。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "c11 터미널 내에서 시작된 프로세스만 명령을 보낼 수 있습니다."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Только процессы, запущенные в терминалах c11, могут отправлять команды."
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Тільки процеси, запущені в терміналах c11, можуть надсилати команди."
          }
        }
      }
    },
    "socketControl.cmuxOnly.name": {
      "extractionState": "manual",
      "localizations": {
